<section class="hero" style="background-color: {{ section.settings.bg_color }}">
  <div class="hero__container">

    <div class="hero__content">
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="hero__title">{{ section.settings.title }}</h1>
      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
      <a href="{{ section.settings.button_url }}" class="btn btn--primary">
        {{ section.settings.button_label }}
      </a>
    </div>

    <div class="hero__image">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: '600x' }}" alt="{{ section.settings.title }}" />
      {% else %}
        <div class="hero__image-placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Glow from within."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Science-backed skincare formulated for real results. Clean ingredients, visible difference."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "color